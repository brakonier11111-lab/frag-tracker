{
  "name": "frag-tracker",
  "version": "2.0.0",
  "description": "Трекер донатов и фрагов для стримеров",
  "main": "electron/main.js",
  "author": "Streamer",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node init-db.js",
    "test": "node --test \"tests/**/*.test.js\" && node scripts/test-donation-poll-filter.js",
    "test:all": "npm test && npm run smoke-test && npm run test-pipeline && npm run test-lesta",
    "smoke-test": "node scripts/smoke-test.js",
    "test-pipeline": "node scripts/test-donation-pipeline.js",
    "test-lesta": "node scripts/test-lesta-sync.js",
    "test-poll-filter": "node scripts/test-donation-poll-filter.js",
    "build:media-art": "dotnet publish scripts/media-art/MediaArt.csproj -c Release -r win-x64 --self-contained true -p:PublishSingleFile=true -o scripts/media-art/out",
    "backup-db": "node scripts/backup-db.js",
    "stagewise": "stagewise",
    "electron": "electron .",
    "electron:dev": "electron .",
    "build:desktop": "electron-builder --win",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint .",
    "lint:errors": "eslint . --quiet"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "centrifuge": "^5.0.0",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.0",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.1.0",
    "multer": "^1.4.5-lts.1",
    "sqlite3": "^5.1.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^8.57.1",
    "nodemon": "^3.0.0",
    "stagewise": "^0.11.1"
  },
  "build": {
    "appId": "com.streamer.frag-tracker",
    "productName": "Frag Tracker",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "src/**/*",
      "server.js",
      "analytics.js",
      "init-db.js",
      "public/**/*",
      "archive/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "package.json",
      "config.env.example"
    ],
    "asarUnpack": [
      "**/node_modules/sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "config.env.example",
        "to": "config.env.example"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Frag Tracker"
    }
  },
  "keywords": [
    "donationalerts",
    "tracker",
    "streaming"
  ],
  "allowScripts": {
    "electron@33.2.0": true,
    "fsevents@2.3.3": true,
    "protobufjs@7.6.4": true,
    "sqlite3@5.1.7": true
  }
}
