@echo off
chcp 65001 >nul
echo Инициализация базы данных для виджета сбора донатов...

cd /d "%~dp0"
node init-db.js

if %errorlevel% equ 0 (
    echo ✅ База данных успешно инициализирована!
    echo ✅ Добавлены таблицы для сбора донатов
) else (
    echo ❌ Ошибка инициализации базы данных
)

pause

