{
  "name": "frag-tracker",
  "version": "3.0.0",
  "description": "Трекер донатов и фрагов для стримеров (refactored)",
  "main": "server-new.js",
  "scripts": {
    "start": "node server-new.js",
    "dev": "nodemon server-new.js",
    "init-db": "node src/cli/init-database.js",
    "migrate": "node src/cli/migrate.js",
    "migrate:create": "node src/cli/migrate.js create",
    "migrate:rollback": "node src/cli/migrate.js rollback",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "express": "^4.18.0",
    "express-validator": "^7.0.0",
    "ws": "^8.14.0",
    "sqlite3": "^5.1.0",
    "dotenv": "^16.4.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "centrifuge": "^5.0.0",
    "cheerio": "^1.0.0-rc.12"
  },
  "devDependencies": {
    "nodemon": "^3.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1"
  },
  "keywords": ["donationalerts", "tracker", "streaming", "obs", "widgets"],
  "author": "Streamer",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}







