# ===================================
# Frag Tracker v3.0 - Configuration
# Скопируйте в config.env и заполните. config.env не коммитить!
# ===================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Пути (опционально). Задаются в окружении ОС ДО запуска (не в config.env —
# FRAG_USER_DATA сам участвует в поиске config.env).
# FRAG_APP_ROOT  — корень приложения (код)
# FRAG_USER_DATA — папка данных: config.env, frag_tracker.db, логи, backups.
#                  По умолчанию %LOCALAPPDATA%\FragTracker; при первом запуске
#                  БД автоматически копируется туда из корня проекта.
# FRAG_LOG_DIR   — отдельная папка логов (иначе FRAG_USER_DATA\logs)
# FRAG_APP_ROOT=
# FRAG_USER_DATA=
# FRAG_LOG_DIR=

# DonationAlerts Configuration
DA_CLIENT_ID=your_client_id
DA_CLIENT_SECRET=your_client_secret
DA_REDIRECT_URI=http://localhost:3000/auth/callback

# DonatePay Configuration (optional)
DP_API_KEY=your_api_key
DP_WEBHOOK_SECRET=your_webhook_secret

# Опрос DonationAlerts/DonatePay — включён по умолчанию (0 = отключить)
# DONATION_POLLING=0

# Lesta Games Configuration (optional)
LESTA_APPLICATION_ID=your_application_id

# Автосинхронизация Lesta — включена по умолчанию (0 = отключить)
# LESTA_AUTOSYNC=0
# Тюнинг дельта-логики боёв (значения по умолчанию указаны)
# LESTA_TANK_SNAPSHOT_MIN_SEC=600
# LESTA_HISTORY_HEARTBEAT_SEC=600
# LESTA_MAX_BATTLES_DELTA=50
# LESTA_RELIABLE_BATTLES_GAP=2

# РазБЛОГировка 2026 — включена по умолчанию (0 = отключить)
# RAZBLOG_ENABLED=0

# Replay Live (optional)
# TANKS_BLITZ_DIR=E:\Games\Tanks_Blitz   (или REPLAY_LIVE_GAME_DIR)
# REPLAY_LIVE_PLAYER=Xasya
# REPLAY_VISUAL_LAG_SEC=1

# YouTube OAuth (optional)
YT_CLIENT_ID=your_client_id
YT_CLIENT_SECRET=your_client_secret
YT_REDIRECT_URI=http://localhost:3000/oauth/youtube/callback

# VK Play OAuth (optional) — секреты только в config.env, не в example!
VKPLAY_CLIENT_ID=your_client_id
VKPLAY_CLIENT_SECRET=your_client_secret
VKPLAY_REDIRECT_URI=http://localhost:3000/oauth/vkplay/callback

# VK Play Bot OAuth (optional) - для чат-бота
VKPLAY_BOT_CLIENT_ID=your_bot_client_id
VKPLAY_BOT_CLIENT_SECRET=your_bot_client_secret
VKPLAY_BOT_REDIRECT_URI=http://localhost:3000/oauth/vkplay-bot/callback

# Опрос VK Play (онлайн/лайки/чат) — ВЫКЛЮЧЕН по умолчанию, 1 = включить.
# Без этого /integrations/vkplay/status застывает.
VKPLAY_POLLING=1

# Twitch (optional) - App Access Token (client_credentials), без OAuth-логина пользователя
# Создать приложение: dev.twitch.tv/console/apps
TW_CLIENT_ID=your_client_id
TW_CLIENT_SECRET=your_client_secret
TW_CHANNEL=your_channel_login

# Twitch (optional): отслеживание новых фолловеров через EventSub channel.follow.
# Требует то же приложение на dev.twitch.tv/console/apps с добавленным redirect URI.
TW_REDIRECT_URI=https://your-domain.example/oauth/twitch/callback
TW_EVENTSUB_CALLBACK_URL=https://your-domain.example
TW_EVENTSUB_SECRET=random_string_10_to_100_chars

# HTTPS (optional) — сертификат генерируется автоматически через PowerShell
HTTPS_ENABLED=false
HTTPS_PORT=3443

# Отладочные флаги (1 = включить подробный лог)
# DEBUG_POLL=1        — цикл опроса донатов
# DEBUG_API=1         — HTTP-запросы к внешним API
# DEBUG_STATE=1       — изменения app-state
# DEBUG_BROADCAST=1   — WebSocket-рассылка
# DEBUG_LESTA=1       — синхронизация Lesta
# DEBUG_VK=1          — VK Play интеграция
