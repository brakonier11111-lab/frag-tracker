{
    "root": true,
    "env": {
        "node": true,
        "es2022": true
    },
    "parserOptions": {
        "ecmaVersion": 2022,
        "sourceType": "script"
    },
    "extends": "eslint:recommended",
    "rules": {
        "no-unused-vars": ["warn", { "args": "none", "varsIgnorePattern": "^_" }],
        "no-empty": ["warn", { "allowEmptyCatch": true }],
        "no-useless-escape": "warn",
        "no-regex-spaces": "warn",
        "no-console": "off"
    },
    "overrides": [
        {
            "files": ["tests/**/*.js"],
            "env": { "node": true }
        }
    ]
}
